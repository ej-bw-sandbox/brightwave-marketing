---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import SimplePage from '@/components/astro/SimplePage.astro'
import { safeFetch } from '@/lib/sanity/client'
import { referralQuery } from '@/lib/sanity/queries/referral'
const doc = await safeFetch<any>(referralQuery, {}, {})
const title = doc.headline || 'Referral Program'
const description = doc.supportingText || ''
---
<MarketingLayout title={title} description={description} seo={doc.seo} path="/referral">
  <SimplePage title={title} subtitle={description} body={null} ctaLabel={doc.heroPrimaryCta?.label || doc.ctaText || doc.heroCta || 'Get a Demo'} ctaUrl={doc.heroPrimaryCta?.url || doc.ctaUrl || '/contact'} />
</MarketingLayout>
