---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import { ProductFilterGrid } from '@/components/sections/ProductFilterGrid'
import { safeFetch } from '@/lib/sanity/client'
import { solutionsIndexQuery } from '@/lib/sanity/queries/solutions'
const data = await safeFetch<any[]>(solutionsIndexQuery, {}, [])
const items = data.map((item:any)=>({ _id:item._id, title:item.title, slug:item.slug, product:item.product, excerpt:item.excerpt || item.eyebrow || '', tag:item.product === 'private-markets' ? 'Private Markets' : '', heroImage:item.heroImage }))
---
<MarketingLayout title="Firm Types | Brightwave" description="AI-powered research solutions built for your firm type." path="/firm-types">
  <ProductFilterGrid client:load items={items} basePath="/firm-types" pageTitle="Firm Types" pageDescription="AI-powered research solutions tailored to how your firm operates." emptyLabel="firm types" />
</MarketingLayout>
