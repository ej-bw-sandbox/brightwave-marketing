---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import IndexHero from '@/components/astro/IndexHero.astro'
import CardGrid from '@/components/astro/CardGrid.astro'
import { safeFetch } from '@/lib/sanity/client'
import { icpIndexQuery } from '@/lib/sanity/queries/icps'
const data = await safeFetch<any>(icpIndexQuery, {}, [])
const items = Array.isArray(data) ? data : (data.studies ?? data.posts ?? [])
---
<MarketingLayout title="Roles | Brightwave" description="Brightwave workflows built for every investment role." path="/i-am-a">
  <IndexHero title="Roles" description="Brightwave workflows built for every investment role." />
  <CardGrid items={items} base="/i-am-a" imageField="heroImage" />
</MarketingLayout>
