---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import { ProductFilterGrid } from '@/components/sections/ProductFilterGrid'
import { safeFetch } from '@/lib/sanity/client'
import { icpIndexQuery } from '@/lib/sanity/queries/icps'
const data = await safeFetch<any[]>(icpIndexQuery, {}, [])
const items = data.map((item:any)=>({ _id:item._id, title:item.title, slug:item.slug, product:item.product, excerpt:item.excerpt || item.heroTagline || '', tag:item.product === 'private-markets' ? 'Private Markets' : '', heroImage:item.heroImage }))
---
<MarketingLayout title="Roles | Brightwave" description="Brightwave is built for financial professionals across every role." path="/i-am-a">
  <ProductFilterGrid client:load items={items} basePath="/i-am-a" pageTitle="Built for Your Role" pageDescription="Brightwave is designed for financial professionals across every role and level." emptyLabel="roles" />
</MarketingLayout>
