---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import IndexHero from '@/components/astro/IndexHero.astro'
import CardGrid from '@/components/astro/CardGrid.astro'
import { safeFetch } from '@/lib/sanity/client'
import { featureIndexQuery } from '@/lib/sanity/queries/features'
const data = await safeFetch<any>(featureIndexQuery, {}, [])
const items = Array.isArray(data) ? data : (data.studies ?? data.posts ?? [])
---
<MarketingLayout title="Platform Features | Brightwave" description="Explore the AI-powered capabilities built for investment research and diligence." path="/features">
  <IndexHero title="Platform Features" description="Explore the AI-powered capabilities built for investment research and diligence." />
  <CardGrid items={items} base="/features" imageField="heroImage" />
</MarketingLayout>
