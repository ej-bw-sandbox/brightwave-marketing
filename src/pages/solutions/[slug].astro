---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Cta from '@/components/astro/Cta.astro'
import PortableText from '@/components/astro/PortableText.astro'
import { safeFetch } from '@/lib/sanity/client'
import { assetUrl } from '@/lib/sanity/image'
import { textFromPortable, stripDraftLabels, stripHtml } from '@/lib/astro/text'
import { solutionQuery, solutionSlugsQuery } from '@/lib/sanity/queries/solutions'

export async function getStaticPaths() {
  const slugs = await safeFetch<any[]>(solutionSlugsQuery, {}, [])
  return slugs.map((item:any) => ({ params: { slug: item.slug } }))
}
const slug = Astro.params.slug!
const basePath = Astro.url.pathname.startsWith('/solutions') ? '/solutions' : '/firm-types'
const doc = await safeFetch<any>(solutionQuery, { slug }, null)
if (!doc) Astro.response.status = 404
const title = doc ? (stripDraftLabels(doc.h1) || doc.title || 'Firm Type') : 'Not Found'
const description = doc ? stripDraftLabels(doc.seo?.metaDescription || doc.heroH2 || doc.excerpt || textFromPortable(doc.heroBody, '')) : ''
const img = doc ? assetUrl(doc.heroImage) : ''
const capabilities = doc?.capabilities ?? []
const valueCards = doc?.valueCards ?? []
const integrations = doc?.integrations ?? []
const implementationSteps = doc?.implementationSteps ?? []
const differentiators = doc?.differentiators ?? []
const faqs = doc?.faqs ?? []
function plain(v:any){ return stripHtml(typeof v === 'string' ? v : textFromPortable(v,'')) }
const trustBadges = ['SOC 2 Type II','No Training on Your Data','End-to-End Encryption','Full Audit Trail']
---
<MarketingLayout title={title} description={description} seo={doc?.seo} path={`${basePath}/${slug}`} type="article">
  {doc ? <div class="main">
    <section class="c-section cc-template">
      <div class="c-container"><div class="ft-hero-grid"><div class="ft-hero-content">
        {doc.eyebrow && <div class="eyebrow cc-no-bp"><div class="block cc-primary"></div><span class="c-title-5">{plain(doc.eyebrow)}</span></div>}
        <div class="bp40-underline"><h1 class="c-title-2">{title}</h1></div>
        {doc.heroH2 && <p class="c-text-3 u-balance">{plain(doc.heroH2)}</p>}
        {doc.heroH3 && <p class="c-text-4" style="color: var(--lightmode--primary, #e7e70d); font-weight: 600">{plain(doc.heroH3)}</p>}
        <PortableText value={doc.heroBody} class="c-text-4" />
        <div class="h-20 cc-hero" style="display:flex; flex-wrap:wrap; gap:1rem; margin-top:.5rem"><Cta href="https://app.brightwave.io/register" label="Start Free Trial" /><Cta href="/contact" label="Get a Demo" variant="outline" /></div>
      </div><div class="ft-hero-media"><div style="position:relative; width:100%; aspect-ratio:16/9; border-radius:.75rem; overflow:hidden; background:rgba(255,255,255,.04); border:1px solid rgba(255,255,255,.08)">{img ? <img src={img} alt={title} class="img-cover cc-abso" /> : null}</div></div></div></div>
    </section>

    {(doc.challengeH2 || doc.operationalPressures || doc.traditionalFailures) && <section class="c-section iam-value"><div class="c-container"><div style="text-align:center;max-width:48rem;margin:0 auto 4rem"><div class="eyebrow cc-no-bp" style="display:inline-flex;justify-content:center;margin-bottom:1rem"><div class="block cc-primary"></div><span class="c-title-5">The Challenge</span></div>{doc.challengeH2 && <h2 class="c-title-2 iam-value__h2" style="margin-bottom:1rem">{plain(doc.challengeH2)}</h2>}{doc.challengeH3 && <p class="c-text-4" style="color:rgba(255,255,255,.7)">{plain(doc.challengeH3)}</p>}</div><div class="bw-card-grid two">{doc.operationalPressures && <div class="iam-value-cell"><h3 class="c-title-5">Operational Pressures</h3><PortableText value={doc.operationalPressures} class="c-text-5" /></div>}{doc.traditionalFailures && <div class="iam-value-cell"><h3 class="c-title-5">Where Traditional Approaches Fail</h3><PortableText value={doc.traditionalFailures} class="c-text-5" /></div>}</div></div></section>}

    {(doc.solutionH2 || capabilities.length > 0) && <section class="c-section"><div class="c-container icp-capabilities"><div style="text-align:center;margin-bottom:3rem;width:100%"><div class="eyebrow cc-no-bp blue" style="display:inline-flex;justify-content:center;margin-bottom:1rem"><div class="block blue"></div><span class="c-title-5">The Solution</span></div>{doc.solutionH2 && <h2 class="c-title-4 icp-capabilities-h2" style="margin-bottom:1rem">{plain(doc.solutionH2)}</h2>}{doc.solutionH3 && <p class="c-text-3 u-balance" style="max-width:48rem;margin:0 auto 1rem">{plain(doc.solutionH3)}</p>}<PortableText value={doc.solutionBody} class="c-text-4" /></div><div class="bw-card-grid">{capabilities.map((c:any, i:number) => <div class="iam-capability-cell shadow-card"><div class="c-text-6">{String(i+1).padStart(2,'0')}</div><h3 class="c-text-2 icp-capabilities__h3">{plain(c.title || c)}</h3><PortableText value={c.bullets} class="c-text-5" /></div>)}</div></div></section>}

    {(doc.valueH2 || valueCards.length > 0 || doc.valueSummary) && <section class="c-section" style="background:var(--lightmode--surface-1,#eff1f5)"><div class="c-container"><div style="text-align:center;margin-bottom:3rem"><div class="eyebrow cc-no-bp" style="display:inline-flex;justify-content:center;margin-bottom:1rem"><div class="block cc-primary"></div><span class="c-title-5">Outcomes</span></div>{doc.valueH2 && <h2 class="c-title-3" style="margin-bottom:1rem">{plain(doc.valueH2)}</h2>}{doc.valueH3 && <p class="c-text-4" style="color:var(--lightmode--onsurface-weak,#5a5b5c);max-width:48rem;margin:0 auto">{plain(doc.valueH3)}</p>}</div><div class="bw-card-grid">{valueCards.map((card:any, i:number) => <div class="iam-capability-cell shadow-card" style="background:#fff"><div class="c-text-6">{String(i+1).padStart(2,'0')}</div><h3 class="c-title-5">{plain(card.title || card)}</h3><PortableText value={card.bullets} class="c-text-5" /></div>)}</div>{doc.valueSummary && <div class="bw-dark-strip"><PortableText value={doc.valueSummary} class="c-text-4" /></div>}</div></section>}

    {(doc.securityH2 || doc.securityArchitecture || doc.complianceFeatures) && <section class="c-section iam-value"><div class="c-container"><div style="text-align:center;max-width:48rem;margin:0 auto 3rem"><div class="eyebrow cc-no-bp" style="display:inline-flex;justify-content:center;margin-bottom:1rem"><div class="block cc-primary"></div><span class="c-title-5">Security & Compliance</span></div>{doc.securityH2 && <h2 class="c-title-3" style="color:#fff;margin-bottom:1rem">{plain(doc.securityH2)}</h2>}{doc.securityH3 && <p class="c-text-4" style="color:rgba(255,255,255,.7)">{plain(doc.securityH3)}</p>}</div><div class="bw-card-grid two">{doc.securityArchitecture && <div class="iam-value-cell"><h3 class="c-title-5">Security Architecture</h3><PortableText value={doc.securityArchitecture} class="c-text-5" /></div>}{doc.complianceFeatures && <div class="iam-value-cell"><h3 class="c-title-5">Compliance Features</h3><PortableText value={doc.complianceFeatures} class="c-text-5" /></div>}</div><div class="bw-trust-row">{trustBadges.map((label) => <div class="c-text-5">✓ {label}</div>)}</div></div></section>}

    {(doc.integrationH2 || integrations.length > 0) && <section class="c-section"><div class="c-container"><div class="v-40"><div class="eyebrow cc-no-bp blue"><div class="block blue"></div><div class="c-title-5">Integrations</div></div>{doc.integrationH2 && <h2 class="c-title-4">{plain(doc.integrationH2)}</h2>}{doc.integrationH3 && <p class="c-text-4">{plain(doc.integrationH3)}</p>}<div class="bw-card-grid">{integrations.map((item:any) => <div class="partner-proof_point"><h3 class="c-title-5">{plain(item.title)}</h3><PortableText value={item.bullets} class="c-text-5" /></div>)}</div></div></div></section>}

    {(doc.resultsQuote || doc.performanceBullets || doc.roiBullets) && <section class="c-section"><div class="c-container"><div class="slider-wrap"><img width="294.5" loading="lazy" alt="" src="/webflow-images/testimonial.svg" class="slider_img" />{doc.resultsQuote && <div class="slider_item"><div class="slider_flex"><div class="c-title-4">{plain(doc.resultsQuote)}</div>{doc.resultsAttribution && <div class="eyebrow-flex"><div class="block cc-primary"></div><div class="c-title-5 cc-primary">{plain(doc.resultsAttribution)}</div></div>}</div></div>}</div><div class="bw-card-grid two" style="margin-top:2rem">{doc.performanceBullets && <div class="partner-proof_point"><h3 class="c-title-5">Performance</h3><PortableText value={doc.performanceBullets} class="c-text-5" /></div>}{doc.roiBullets && <div class="partner-proof_point"><h3 class="c-title-5">ROI</h3><PortableText value={doc.roiBullets} class="c-text-5" /></div>}</div></div></section>}

    {(doc.implementationH2 || implementationSteps.length > 0 || doc.differentiationH2 || differentiators.length > 0) && <section class="c-section"><div class="c-container"><div class="v-48">{doc.implementationH2 && <h2 class="c-title-4">{plain(doc.implementationH2)}</h2>}<div class="ent-price-timeline-grid">{implementationSteps.map((step:any, i:number) => <div class="ent-price-timeline-item"><div class="ent-price-timeline-top"><div class="ent-price-timeline-box"></div><div class="c-title-5">{String(i+1).padStart(2,'0')}</div><div class="ent-price-divider"></div></div><div class="ent-price-timeline-bottom"><div class="c-text-4 cc-weight-500">{plain(step.title)}</div><div>{plain(step.description)}</div></div></div>)}</div>{doc.differentiationH2 && <h2 class="c-title-4" style="margin-top:3rem">{plain(doc.differentiationH2)}</h2>}<div class="bw-card-grid">{differentiators.map((item:any) => <div class="ent-price-dark-card"><div class="ent-price-dark-card_header"><div class="eyebrow-box"></div><div class="c-title-5">{plain(item.title)}</div></div><div class="c-text-5">{plain(item.body)}</div></div>)}</div></div></div></section>}

    {faqs.length > 0 && <section class="c-section"><div class="c-container"><div class="v-40"><h2 class="c-title-2">{doc.faqTitle || 'Frequently asked questions'}</h2><div>{faqs.map((faq:any) => <details class="bw-faq"><summary class="c-text-2 cc-balance">{plain(faq.question)}</summary><div class="c-text-4"><PortableText value={faq.answer} /></div></details>)}</div></div></div></section>}

    <section class="c-section"><div class="c-container"><div class="v-48" style="max-width:42rem;margin:0 auto;text-align:center;align-items:center"><h2 class="c-title-4">{plain(doc.ctaH2) || 'Ready to get started?'}</h2>{doc.ctaSubheadline && <p class="c-text-4">{plain(doc.ctaSubheadline)}</p>}<PortableText value={doc.ctaBody} class="c-text-4" /><div class="h-20" style="justify-content:center;flex-wrap:wrap"><Cta href="https://app.brightwave.io/register" label={doc.ctaButtonLabel || 'Start Free Trial'} /><Cta href="/contact" label="Get a Demo" variant="outline" /></div>{doc.ctaTagline && <div class="c-text-5">{plain(doc.ctaTagline)}</div>}</div></div></section>
  </div> : <section class="c-section"><div class="c-container"><h1 class="c-title-1">Not found</h1></div></section>}
  <style is:inline>
    .ft-hero-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:3.5rem;align-items:center}.ft-hero-content{display:flex;flex-direction:column;gap:1.25rem}.bw-card-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,20rem),1fr));gap:1.5rem;width:100%}.bw-card-grid.two{grid-template-columns:repeat(auto-fit,minmax(min(100%,22rem),1fr))}.iam-value-cell{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.08);border-radius:.5rem;padding:2rem;color:#fff}.bw-dark-strip{margin:3rem auto 0;background:var(--lightmode--onsurface,#0f0f0f);color:#fff;border-radius:.75rem;padding:2.5rem;line-height:1.7;max-width:64rem}.bw-trust-row{display:flex;flex-wrap:wrap;gap:2rem;justify-content:center;margin-top:2rem;opacity:.72}.bw-faq{border-bottom:1px solid var(--lightmode--onsurface-border,#d7d8db);padding:1.25rem 0}.bw-faq summary{cursor:pointer;list-style:none;display:flex;justify-content:space-between;gap:1rem}.bw-faq summary:after{content:'+';font-size:1.5rem}@media(max-width:991px){.ft-hero-grid{grid-template-columns:1fr;gap:2.5rem}}
  </style>
</MarketingLayout>
