---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import SimplePage from '@/components/astro/SimplePage.astro'
import { safeFetch } from '@/lib/sanity/client'
import { thank_you_contactQuery } from '@/lib/sanity/queries/thank-you-contact'
const doc = await safeFetch<any>(thank_you_contactQuery, {}, {})
const title = doc.heroHeading || 'Thank you'
const description = doc.heroBody || 'We received your message and will be in touch shortly.'
---
<MarketingLayout title={title} description={description} seo={doc.seo} path="/thank-you-contact">
  <SimplePage title={title} subtitle={description} body={null} ctaLabel={doc.heroPrimaryCta?.label || doc.ctaText || doc.heroCta || 'Get a Demo'} ctaUrl={doc.heroPrimaryCta?.url || doc.ctaUrl || '/contact'} />
</MarketingLayout>
