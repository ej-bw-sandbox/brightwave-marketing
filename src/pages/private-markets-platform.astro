---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import SimplePage from '@/components/astro/SimplePage.astro'
import { safeFetch } from '@/lib/sanity/client'
import { private_markets_platformQuery } from '@/lib/sanity/queries/private-markets-platform'
const doc = await safeFetch<any>(private_markets_platformQuery, {}, {})
const title = doc.heroHeadline || 'Private Markets Platform'
const description = doc.heroDescription || ''
---
<MarketingLayout title={title} description={description} seo={doc.seo} path="/private-markets-platform">
  <SimplePage title={title} subtitle={description} body={null} ctaLabel={doc.heroPrimaryCta?.label || doc.ctaText || doc.heroCta || 'Get a Demo'} ctaUrl={doc.heroPrimaryCta?.url || doc.ctaUrl || '/contact'} />
</MarketingLayout>
