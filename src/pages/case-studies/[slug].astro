---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Cta from '@/components/astro/Cta.astro'
import PortableText from '@/components/astro/PortableText.astro'
import { safeFetch } from '@/lib/sanity/client'
import { assetUrl } from '@/lib/sanity/image'
import { slugValue, textFromPortable } from '@/lib/astro/text'
import { caseStudyQuery, caseStudySlugsQuery } from '@/lib/sanity/queries/case-studies'
export async function getStaticPaths() {
  const slugs = await safeFetch<any[]>(caseStudySlugsQuery, {}, [])
  return slugs.map((item:any) => ({ params: { slug: item.slug } }))
}
const slug = Astro.params.slug!
const doc = await safeFetch<any>(caseStudyQuery, { slug }, null)
if (!doc) { Astro.response.status = 404 }
const title = doc ? (doc.title || 'Case Study') : 'Not Found'
const description = doc ? (doc.seo?.metaDescription || doc.heroDescription || doc.excerpt || '') : ''
const img = doc ? assetUrl(doc.heroImage || doc.coverImage || doc.thumbnail || doc.heroImage || doc.competitorLogo) : ''
---
<MarketingLayout title={title} description={description} seo={doc?.seo} path={`/case-studies/${slug}`} type="article">
  {doc ? <>
    <section class="c-section cc-template"><div class="c-container"><div class="content"><div class="grid cc-template"><div class="template"><a href="/case-studies" class="eyebrow-flex cc-mobile w-inline-block"><div class="block"></div><div class="c-title-5">Go back</div></a><h1 class="c-title-3 cc-template">{title}</h1><div class="c-text-4">{description}</div><div class="h-20" style="margin-top:1.5rem"><Cta href="/contact" label="Get a Demo" /></div></div><div class="u-overflow-hidden"><div class="aspect-16-9 cc-relative">{img ? <img src={img} alt={title} class="img-cover cc-abso" /> : <img src="https://d3e54v103j8qbb.cloudfront.net/plugins/Basic/assets/placeholder.60f9b1840c.svg" alt="" class="img-cover cc-abso w-dyn-bind-empty" />}</div></div></div></div></div></section>
    <section class="c-section"><div class="c-container"><div class="rich-text w-richtext"><PortableText value={doc.body || doc.heroBody || doc.solutionBody || doc.securityContent || doc.socialContent || doc.ctaBody} /></div></div></section>
    {(doc.capabilityPillars || doc.valuePillars || doc.challenges || doc.solutions || doc.featureHighlights || doc.capabilities || doc.contentBlocks || doc.faqs)?.length > 0 && <section class="c-section"><div class="c-container"><div class="grid cc-cards w-dyn-items">{(doc.capabilityPillars || doc.valuePillars || doc.challenges || doc.solutions || doc.featureHighlights || doc.capabilities || doc.contentBlocks || doc.faqs || []).slice(0,12).map((item:any)=><div class="partner-proof_point"><h3 class="c-title-5">{item.title || item.question || item.heading}</h3><div class="c-text-4">{item.description || item.body || item.answer || (Array.isArray(item.bullets) ? item.bullets.join(', ') : '')}</div></div>)}</div></div></section>}
  </> : <section class="c-section"><div class="c-container"><h1 class="c-title-1">Not found</h1></div></section>}
</MarketingLayout>
