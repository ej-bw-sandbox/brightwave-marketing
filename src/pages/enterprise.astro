---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Cta from '@/components/astro/Cta.astro'
import Lottie from '@/components/astro/Lottie.astro'
import { RoiCalculator } from '@/components/islands/RoiCalculator'
import { safeFetch } from '@/lib/sanity/client'
import { enterpriseQuery } from '@/lib/sanity/queries/enterprise'
const doc = await safeFetch<any>(enterpriseQuery, {}, {})
const title = doc.heroHeadline || 'Enterprise'
const description = doc.heroSubheadline || 'Brightwave for enterprise teams.'
const marqueeLogos = ['fortune.avif','axios.avif','american-banker.avif','wjs-pro.avif','tech-crunch.avif','time_1.avif','latent.avif','fox-business.avif','%3Edf.avif','cerebral.avif']
---
<MarketingLayout title={title} description={description} seo={doc.seo} path="/enterprise">
  <div class="w-embed"><style is:inline>[slider-accordion].cc-active [slider-text]{color:var(--darkmode--onsurface)}.u-dark-mode [slider-accordion].cc-active [slider-text]{color:var(--grey-800)!important}.ui-slider_left_item.cc-active .slider-ui_left_icon-wrap{background-color:var(--lightmode--primary)}.ui-slider_left_item.cc-active .slider-ui_left_icon{filter:brightness(0)}html.wf-design-mode .num-slider_item{display:none}.u-dark-mode .marquee-logo{filter:invert(1)}</style></div>
  <div class="main">
    <section class="c-section ent-price-hero"><div class="c-container"><div class="ent-pricing_hero-content"><div class="c-ent-price_hero-wrapper"><div><h1 class="c-title-3">{title}</h1></div><div class="text-cta ent-price-hero"><div><div class="c-text-3">{description}</div></div><div class="h-20">{(doc.heroCtas?.length?doc.heroCtas:[{label:'Contact Sales',url:'/contact'},{label:'Get a Demo',url:'/contact',style:'outline'}]).map((cta:any, i:number)=><Cta href={cta.url} label={cta.label} variant={i === 0 ? 'primary' : 'outline'} />)}</div></div></div><div class="c-ent-price_wizard-wrapper"><RoiCalculator client:visible title={doc.roiCalcTitle || 'Get Started'} ctaLabel={doc.roiCalcCtaLabel || 'Schedule a Demo'} ctaUrl={doc.roiCalcCtaUrl || 'https://calendly.com/d/cv37-bhv-664/brightwave-trial'} formConfig={doc.wizardForm} /></div></div></div></section>
    <section class="c-section cc-program-lottie"><div class="c-container"><div lottie-bg class="lottie-crop cc-market"><Lottie src="/webflow-documents/Generative-Loop-Final-25.json" class="lottie_cropped-desktop cc-market" /><Lottie src="/webflow-documents/Generative-Loop-Final.json" class="lottie_cropped-mobile" /></div></div></section>

    <section class="c-section ent-pricing-proofs"><div class="c-container"><div class="partner-proofs_main-wrapper"><div><div class="small-marquee_wrapper"><div class="small-marquee_header"><div class="c-title-5">{doc.socialProofHeadline}</div></div><div data-marquee class="marquee-horizontal"><div class="marquee"><div class="marquee__group">{[...marqueeLogos,...marqueeLogos].map((logo)=><div class="marquee-logo"><img src={`/webflow-images/${logo}`} loading="lazy" alt="" /></div>)}</div></div></div></div></div><div class="partner-proofs_wrapper"><div><div class="eyebrow cc-no-bp blue"><div class="block blue"></div><div class="c-title-5">{doc.proofPointsEyebrow}</div></div></div><div class="partner-proof_points col-3">{(doc.proofPoints||[]).map((point:any)=><div class="partner-proof_point"><h3 class="c-title-4">{point.value}</h3><div class="c-text-4">{point.description}</div></div>)}</div></div></div></div></section>

    <section class="c-section ent-price-research"><div class="c-container"><div class="v-64 cc-stretch"><div class="ent-price-research_header"><h2 class="c-title-3">{doc.researchHeadline}</h2></div><div class="c-abm-temp-chal_header-wrapper"><div class="c-abm-temp-chal_header"><div class="c-amb-temp-chal_box"></div><div class="c-title-5">{doc.researchEyebrow}</div></div></div><div class="ent-price-research_main-wrapper"><div class="stretch-child"><div class="c-text-4">{doc.researchBody}</div></div><div class="stretch-child img"><div class="partner-about_image-wrapper"><Lottie src="/webflow-documents/About-Lottie-25.json" class="partner-about_lottie-wrapper" /></div></div></div></div></div></section>

    <section class="c-section ent-price-cards"><div class="c-container"><div class="c-abm-temp_chal_main-wrapper"><div class="c-abm-temp-chal_header-wrapper"><div class="c-abm-temp-chal_header"><div class="c-amb-temp-chal_box"></div><div class="c-title-5">{doc.capabilitiesEyebrow}</div></div></div><div class="c-abm-temp-chal_card-wrapper c-abm-template_grid"><div class="c-amb-temp-chal_sticky"><div class="c-abm-temp-chal_title-wrapper"><h2 class="c-title-3">{doc.capabilitiesStickyTitle}</h2></div><div class="c-abm-temp-chal_button-wrapper"><Cta href="/contact" label="Book a demo" /><Cta href="#" label="See How It Works" variant="outline" /></div></div><div class="c-abm-temp-chal_card-list">{(doc.capabilityCards||[]).map((card:any)=><div><div class="c-abm-temp-chal_card"><div class="c-abm-temp-chal_card-content"><div class="c-text-3 cc-500">{card.title}</div><div class="c-text-5">{card.subtitle}</div></div><div class="c-abm-temp-chal_card-highlight"><div class="c-abm-temp-chal_card-icon-wrapper"><div class="c-abm-temp-chal_icon w-embed">◆</div></div><div class="c-abm-temp-chal_card-text-stack"><div class="c-abm-temp-chal_card-title-wrapper"><div class="c-text-4 cc-weight-500">{card.howHelpsLabel}</div></div><div class="c-abm-temp-chal_card-text-wrapper"><p class="c-text-5">{card.howHelpsText}</p></div></div><div class="c-abm-temp-chal_card-top-box"></div></div></div></div>)}</div></div></div></div></section>

    <section no-fade class="c-section ent-price-slider"><div class="c-container"><div class="slider-wrap"><img width="294.5" loading="lazy" alt="" src="/webflow-images/testimonial.svg" class="slider_img" /><Lottie src="/webflow-documents/Testimonial-BG-25.json" class="slider_lottie" />{(doc.testimonials||[]).length > 0 && <div class="slider_item"><div class="slider_flex"><div class="c-title-4">{doc.testimonials[0].quote}</div><div class="eyebrow-flex"><div class="block cc-primary"></div><div class="c-title-5 cc-primary">{doc.testimonials[0].authorTitle && doc.testimonials[0].company ? `${doc.testimonials[0].authorTitle}, ${doc.testimonials[0].company}` : doc.testimonials[0].attribution}</div></div></div></div>}<div class="slider_test"><div class="c-title-5"><span class="hide-tablet">Featured </span>Quote</div></div></div></div></section>

    <section class="c-section ent-price-numbers"><div class="c-container"><div class="partner-list_wrapper"><div class="partner-list_title"><h3 class="c-title-3">{doc.byTheNumbersHeadline}</h3><Cta href="/contact" label="Book a demo" /></div><div class="partner-list_list-wrapper">{(doc.byTheNumbersItems||[]).map((item:any)=><div class="partner-list_list-item"><div class="partner_icon"><div class="svg w-embed">●</div></div><div class="c-text-3 cc-500">{item.label}</div></div>)}</div></div></div></section>

    <section class="c-section ent-price-cert"><div class="c-container"><div class="v-40"><div class="c-abm-temp-chal_header-wrapper"><div class="c-abm-temp-chal_header"><div class="c-amb-temp-chal_box"></div><div class="c-title-5">{doc.securityEyebrow}</div></div></div><div class="h-flex-20">{(doc.securityCertifications||[]).map((cert:any, i:number)=><div class="explore-item"><div class="aspect-16-9"><div class="u-relative"><img src={i % 2 === 0 ? '/webflow-images/illustration_Enterprise-Trust--Security.svg' : '/webflow-images/illustration_Investment-Intelligence-Engine.svg'} loading="lazy" width="70" alt="" class="image-abso" /></div></div><div class="v-64 cc-fill"><div class="v-20 cc-explore"><div class="c-title-3">{cert.title}</div><div><div class="c-text-4">{cert.description}</div></div></div></div></div>)}</div></div></div></section>

    <section class="c-section ent-price"><div class="c-container"><div class="c-abm-temp_chal_main-wrapper"><div class="c-abm-temp-chal_card-wrapper c-abm-template_grid"><div class="c-amb-temp-chal_sticky"><div class="c-abm-temp-chal_title-wrapper"><h2 class="c-title-2">{doc.securityFeaturesHeadline}</h2></div><div class="c-abm-temp-chal_button-wrapper"><Cta href={doc.securityFeaturesCtaUrl || '/enterprise-security-compliance'} label={doc.securityFeaturesCtaLabel || 'Learn More'} /></div></div><div class="c-abm-temp-chal_card-list">{(doc.securityFeatures||[]).map((feature:any)=><div class="v-12"><div class="c-title-5">{feature.title}</div><div class="c-text-4">{feature.description}</div></div>)}</div></div></div></div></section>

    <section class="c-section ent-price"><div class="c-container"><div class="v-48"><div class="ent-price-head"><h2 class="c-title-4">{doc.whyChooseHeadline}</h2></div><div lottie-bg class="lottie-crop"><Lottie src="/webflow-documents/CTA-Lottie-25.json" class="lottie_cropped-desktop" /><Lottie src="/webflow-documents/Generative-Loop-Final-25.json" class="lottie_cropped-mobile" /></div><div class="ent-price-card-grid">{(doc.whyChooseCards||[]).map((card:any)=><div class="ent-price-dark-card"><div class="ent-price-dark-card_header"><div class="eyebrow-box"></div><div class="c-title-5">{card.eyebrow}</div></div><div><p class="c-text-5">{card.body}</p></div></div>)}</div></div></div></section>

    <section class="c-section ent-price"><div class="c-container"><div class="v-48"><div class="ent-price-head"><h2 class="c-title-3">{doc.timelineHeadline}</h2></div><div class="ent-price-timeline-grid">{(doc.timelineSteps||[]).map((step:any, i:number)=><div class="ent-price-timeline-item"><div class="ent-price-timeline-top"><div class="ent-price-timeline-box"></div><div class="c-title-5">{String(i + 1).padStart(2, '0')}</div><div class="ent-price-divider"></div></div><div class="ent-price-timeline-bottom"><div class="div-block-106"><div class="c-text-4 cc-weight-500">{step.title}</div><div>{step.description}</div></div><div class="div-block-105"><div class="w-embed">✦</div></div></div></div>)}</div></div></div></section>

    <section class="c-section ent-price"><div class="c-container"><div class="v-40"><h2 class="c-title-2">{doc.faqsTitle}</h2><div>{(doc.faqs||[]).map((faq:any)=><div><div class="c-line"></div><details class="accordion-wrap"><summary class="accordion_toggle"><div class="c-text-2 cc-balance">{faq.question}</div><div class="c-svg-2 cc-20 w-embed">+</div></summary><div class="accordion_dropdown"><div class="accordion_content"><div class="c-text-4 w-richtext"><p>{faq.answer}</p></div></div></div></details></div>)}<div class="c-line"></div></div></div></div></section>
  </div>
  <style is:inline>
    :root{--gap:5rem;--duration:30s;--scroll-start:0;--scroll-end:calc(-50% - (var(--gap)/2))}@media(max-width:767px){:root{--gap:2.5rem}}.marquee{display:flex;overflow:hidden;user-select:none;gap:var(--gap);mask-image:linear-gradient(to right,hsl(0 0% 0% / 0),hsl(0 0% 0% / 1) 20%,hsl(0 0% 0% / 1) 80%,hsl(0 0% 0% / 0))}.marquee__group{flex-shrink:0;display:flex;align-items:center;justify-content:space-around;gap:var(--gap);min-width:100%;animation:scroll-x var(--duration) linear infinite}@keyframes scroll-x{from{transform:translateX(var(--scroll-start))}to{transform:translateX(var(--scroll-end))}}[theme="dark"] .ent-price-dark-card,.u-dark-mode .ent-price-dark-card{background-color:var(--colorprimitives--gray-800);color:var(--colorprimitives--gray-50)}[theme="dark"] .ent-price-dark-card .eyebrow-box,.u-dark-mode .ent-price-dark-card .eyebrow-box{background-color:var(--colorprimitives--gray-50)}[theme="dark"] .ent-price-dark-card .c-title-5,[theme="dark"] .ent-price-dark-card .c-text-5,.u-dark-mode .ent-price-dark-card .c-title-5,.u-dark-mode .ent-price-dark-card .c-text-5{color:var(--colorprimitives--gray-50)}.marquee-logo img{max-height:2.5rem;width:auto}
  </style>
</MarketingLayout>
