---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import SimplePage from '@/components/astro/SimplePage.astro'
import { safeFetch } from '@/lib/sanity/client'
import { partner_termsQuery } from '@/lib/sanity/queries/partner-terms'
const doc = await safeFetch<any>(partner_termsQuery, {}, {})
const title = doc.title || 'Partner Terms'
const description = doc.effectiveDate ? `Effective ${doc.effectiveDate}` : ''
---
<MarketingLayout title={title} description={description} seo={doc.seo} path="/partner-terms">
  <SimplePage title={title} subtitle={description} body={doc.body} ctaLabel={doc.heroPrimaryCta?.label || doc.ctaText || doc.heroCta || 'Get a Demo'} ctaUrl={doc.heroPrimaryCta?.url || doc.ctaUrl || '/contact'} />
</MarketingLayout>
