---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import SimplePage from '@/components/astro/SimplePage.astro'
import { safeFetch } from '@/lib/sanity/client'
import { partnersQuery } from '@/lib/sanity/queries/partners'
const doc = await safeFetch<any>(partnersQuery, {}, {})
const title = doc.heroHeading || doc.title || 'Partners'
const description = [doc.heroSubtitlePrefix, doc.heroSubtitleBold, doc.heroSubtitleSuffix].filter(Boolean).join(' ') || doc.description || ''
---
<MarketingLayout title={title} description={description} seo={doc.seo} path="/partners">
  <SimplePage title={title} subtitle={description} body={null} ctaLabel={doc.heroPrimaryCta?.label || doc.ctaText || doc.heroCta || 'Get a Demo'} ctaUrl={doc.heroPrimaryCta?.url || doc.ctaUrl || '/contact'} />
</MarketingLayout>
