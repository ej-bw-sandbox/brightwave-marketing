{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": [
      "astro/client",
      "node"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.astro"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".vercel",
    ".astro",
    "src/app/**",
    "src/sanity/**",
    "src/components/demo/**",
    "src/components/sections/**",
    "src/components/ui/**",
    "src/components/layout/footer.tsx",
    "src/components/layout/header-wrapper.tsx",
    "src/components/layout/logo.tsx",
    "src/components/layout/nav.tsx",
    "src/components/forms/contact-form.tsx",
    "src/components/forms/demo-form.tsx",
    "src/components/forms/resource-gate-form.tsx",
    "src/components/forms/rsvp-form.tsx",
    "src/lib/metadata.ts",
    "src/lib/downloads/**",
    "src/lib/sanity/portable-text-components.tsx"
  ]
}
